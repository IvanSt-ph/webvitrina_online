#!/usr/bin/env bash
set -euo pipefail

# Example backup script for WebVitrina production.
# Put real values into environment variables or a root-only env file.

APP_DIR="${APP_DIR:-/var/www/webvitrina}"
BACKUP_DIR="${BACKUP_DIR:-/var/backups/webvitrina}"
DB_HOST="${DB_HOST:-127.0.0.1}"
DB_PORT="${DB_PORT:-3306}"
DB_DATABASE="${DB_DATABASE:-webvitrina}"
DB_USERNAME="${DB_USERNAME:-webvitrina_user}"
DB_PASSWORD="${DB_PASSWORD:?DB_PASSWORD is required}"
KEEP_DAYS="${KEEP_DAYS:-14}"

STAMP="$(date +%Y%m%d-%H%M%S)"
TARGET_DIR="${BACKUP_DIR}/${STAMP}"

mkdir -p "${TARGET_DIR}"
chmod 700 "${BACKUP_DIR}" "${TARGET_DIR}"

mysqldump \
  --host="${DB_HOST}" \
  --port="${DB_PORT}" \
  --user="${DB_USERNAME}" \
  --password="${DB_PASSWORD}" \
  --single-transaction \
  --quick \
  --routines \
  --triggers \
  "${DB_DATABASE}" | gzip > "${TARGET_DIR}/database.sql.gz"

tar -czf "${TARGET_DIR}/storage-public.tar.gz" -C "${APP_DIR}/storage/app" public

find "${BACKUP_DIR}" -mindepth 1 -maxdepth 1 -type d -mtime "+${KEEP_DAYS}" -exec rm -rf {} +

echo "Backup created: ${TARGET_DIR}"
