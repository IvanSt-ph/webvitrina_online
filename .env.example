# ======================================================
# 🌐 ОСНОВНЫЕ НАСТРОЙКИ ПРИЛОЖЕНИЯ
# ======================================================
APP_NAME=WebVitrina
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

SESSION_DOMAIN=null
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ======================================================
# 🧾 ЛОГИРОВАНИЕ
# ======================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
TWILIO_LOG_LEVEL=warning
REGISTRATION_LOG_LEVEL=warning

ADMIN_EMAIL=
ADMIN_PASSWORD=
SEED_ADMIN_USER=false
SEED_DEMO_PRODUCTS=false

# ======================================================
# 🧩 НАСТРОЙКИ БАЗЫ ДАННЫХ
# ======================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webvitrina
DB_USERNAME=webvitrina_user
DB_PASSWORD=

# ======================================================
# ⚙️ СЕССИИ, КЭШ, ОЧЕРЕДИ
# ======================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
QUEUE_WORKER_COMMAND="php artisan queue:work --sleep=3 --tries=3 --backoff=60 --max-time=3600"
BROADCAST_CONNECTION=log
LOCAL_DISK_SERVE=false
BACKUP_DIR=/var/backups/webvitrina
BACKUP_MAX_AGE_HOURS=30
BACKUP_KEEP_DAYS=14
BACKUP_DAILY_AT=03:15

# ======================================================
# 🔐 REDIS
# ======================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ======================================================
# 💌 ПОЧТА
# ======================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ======================================================
# 🌐 GOOGLE OAUTH
# ======================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ======================================================
# 📱 TWILIO VERIFY
# ======================================================
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ======================================================
# ☁️ AWS (опционально)
# ======================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ======================================================
# 🖼️ ОБРАБОТКА ИЗОБРАЖЕНИЙ
# ======================================================
IMAGE_DRIVER=gd

# ======================================================
# ⚙️ VITE
# ======================================================
VITE_APP_NAME="${APP_NAME}"

# ======================================================
# 💱 КУРСЫ ВАЛЮТ (ДЛЯ ВНУТРЕННЕЙ ЛОГИКИ)
# ======================================================
PRB_PER_MDL=0.9419
PRB_PER_UAH=0.48

# ======================================================
# 🧯 BACKUP
# ======================================================
BACKUP_DIR=/var/backups/webvitrina
BACKUP_MAX_AGE_HOURS=30
BACKUP_KEEP_DAYS=14
BACKUP_DAILY_AT=03:15
