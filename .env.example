# ======================================================
# 🌐 ОСНОВНЫЕ НАСТРОЙКИ ПРИЛОЖЕНИЯ
# ======================================================
APP_NAME=WebVitrina
APP_ENV=local
APP_KEY=               # <--- ОСТАВИТЬ ПУСТЫМ, ключ каждый генерит свой
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

SESSION_DOMAIN=null
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ======================================================
# 🧾 ЛОГИРОВАНИЕ
# ======================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

ADMIN_PASSWORD=0000000000   # Используется в сидере для создания админа

# ======================================================
# 🧩 НАСТРОЙКИ БАЗЫ ДАННЫХ
# ======================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1           # ОБЩИЙ вариант для любого нового ПК
DB_PORT=3306
DB_DATABASE=webvitrina      # Общее имя, можно менять на своём ПК
DB_USERNAME=root
DB_PASSWORD=

# ======================================================
# ⚙️ СЕССИИ, КЭШ, ОЧЕРЕДИ
# ======================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ======================================================
# 🔐 REDIS
# ======================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ======================================================
# 💌 ПОЧТА
# ======================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ======================================================
# ☁️ AWS (опционально)
# ======================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ======================================================
# 🖼️ ОБРАБОТКА ИЗОБРАЖЕНИЙ
# ======================================================
IMAGE_DRIVER=gd

# ======================================================
# ⚙️ VITE
# ======================================================
VITE_APP_NAME="${APP_NAME}"

# ======================================================
# 💱 КУРСЫ ВАЛЮТ (ДЛЯ ВНУТРЕННЕЙ ЛОГИКИ)
# ======================================================
PRB_PER_MDL=0.9419
PRB_PER_UAH=0.48
